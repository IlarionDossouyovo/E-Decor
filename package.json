{
  "name": "e-decor",
  "version": "1.2.0",
  "description": "E-Décor - E-commerce dropshipping pour la decoration d'interieur en partenariat avec ORCA-Décor",
  "main": "main.js",
  "scripts": {
    "start": "node node_modules/electron/cli.js .",
    "postinstall": "electron-builder install-app-deps",
    "build": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac"
  },
  "keywords": [
    "decor",
    "interieur",
    "ameublement",
    "ecommerce",
    "dropshipping",
    "orcadecor"
  ],
  "author": "E-Décor Team",
  "license": "MIT",
  "build": {
    "appId": "com.electron.EDecor",
    "productName": "E-Décor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "assets/**/*",
      "ai-integration/**/*",
      "ai-agents/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^41.7.2",
    "electron-builder": "^24.9.1",
    "vercel": "^51.3.0"
  }
}
